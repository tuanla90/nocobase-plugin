# --- dependencies & toolchains (reinstall per BUILD.md) ---
node_modules/

# --- build-env artifacts (all regenerated by recipes) ---
build-env/node_modules/
build-env/packages/
build-env/storage/

# --- built shared lib (regenerated by recipes/run-shared-build.sh) ---
packages/@ptdl/shared/dist/

# --- local DB snapshots / backups: contain REAL data, never commit ---
_backup-localhost-*/
*.sqlite
*.sqlite3
*.db

# --- historical packaged plugins (large binaries; latest/ holds the current set) ---
archive/

# --- misc ---
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/
