# --- dependencies & toolchains (reinstall per BUILD.md) ---
node_modules/

# --- build-env artifacts (all regenerated by recipes) ---
build-env/node_modules/
build-env/packages/
build-env/storage/

# --- built shared lib (regenerated by recipes/run-shared-build.sh) ---
packages/@tuanla90/shared/dist/

# --- local DB snapshots / backups: contain REAL data, never commit ---
_backup-localhost-*/
*.sqlite
*.sqlite3
*.db

# --- historical packaged plugins (large binaries; latest/ holds the current set) ---
archive/

# --- Claude Code: keep shared config (agents/) but never the machine-local bits ---
.claude/settings.local.json
.claude/worktrees/
**/settings.local.json

# --- npm auth: registry tokens live in .npmrc — NEVER commit (templates use *.example) ---
.npmrc
**/.npmrc
# GitHub Packages publish token (build-env/.ghp-token) — local secret, never commit
.ghp-token
**/.ghp-token
# nb-local API token (build-env/.nb-token) — local secret, never commit
.nb-token
**/.nb-token

# --- misc ---
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/
